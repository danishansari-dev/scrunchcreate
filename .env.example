# Supabase configuration (required for live backend)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# API URL for frontend network requests (legacy, kept for reference)
VITE_API_URL=http://localhost:5000/api

# Cloudinary configuration (used by upload/reseed scripts under scripts/)
# Why: Used by media setup scripts to seed CDN mapping. Rotation required if compromised.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
