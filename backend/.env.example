# ─────────────────────────────────────────────────────────────
# ScrunchCreate — Backend Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# Server port
# Local: 5000 | Render production: 10000
PORT=5000

# Runtime mode — controls error verbosity, stack trace suppression, etc.
# Options: development | production
NODE_ENV=development

# MongoDB Atlas connection string
# Create a free cluster at https://cloud.mongodb.com
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/scrunchcreate

# Secret key used to sign JWT authentication tokens
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-random-64-character-secret-here

# How long JWT tokens remain valid before requiring re-login
# Examples: 1h, 7d, 30d
JWT_EXPIRES_IN=30d

# Frontend URL — used for CORS origin whitelist
# Local: http://localhost:5173 | Production: https://scrunchcreate.vercel.app
CLIENT_URL=http://localhost:5173

# ─────────────────────────────────────────────────────────────
# Google OAuth Authentication
# ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=https://scrunchcreate.onrender.com/api/auth/google/callback

# ─────────────────────────────────────────────────────────────
# Cloudinary — Product image CDN
# Create a free account at https://cloudinary.com
# Find these values in your Cloudinary Dashboard → Settings
# ─────────────────────────────────────────────────────────────

# Your Cloudinary cloud name (from dashboard URL)
CLOUDINARY_CLOUD_NAME=your-cloud-name

# API key for authenticated uploads/management
CLOUDINARY_API_KEY=000000000000000

# API secret (keep this private — never commit to git)
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
